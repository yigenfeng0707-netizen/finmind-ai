{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/ws/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/js/app.js",
      "dest": "/public/js/app.js"
    },
    {
      "src": "/styles/main.css",
      "dest": "/public/styles/main.css"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/index.html",
      "dest": "/public/index.html"
    }
  ],
  "regions": ["sin1"]
}
